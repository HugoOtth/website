#!/usr/bin/env sh

# Pre-push hook that runs the build command
# This will prevent pushing if the build fails

echo "🔧 Running build before push..."

# Run the build command
pnpm run build

# Check if build was successful
if [ $? -eq 0 ]; then
    echo "✅ Build successful! Proceeding with push..."
    # Revert auto-generated files that build may have reformatted
    git checkout -- next-env.d.ts 2>/dev/null || true
    exit 0
else
    echo "❌ Build failed! Push aborted."
    echo "Please fix the build errors before pushing."
    exit 1
fi